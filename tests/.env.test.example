# Integration Test Configuration for plccli
# Copy this file to .env.test and configure for your environment

# PLC Connection
OPCUA_ENDPOINT=opc.tcp://192.168.123.252:4840
OPCUA_USERNAME=
OPCUA_PASSWORD=

# Test Node IDs (Siemens S7-1200)
# DTL node - required for DTL tests
DTL_NODE=ns=4,i=38

# Basic data type nodes - for regression tests
INT32_NODE=ns=4,i=14      # aqua_fill_level
BOOL_NODE=ns=4,i=5        # aqua_refill_ongoing
UINT16_NODE=ns=4,i=26     # grow_room_comp_air_pressure

# Optional nodes (tests will skip if not available)
# STRING_NODE=ns=3,s=SomeStringVar

# Test Configuration
PLCCLI_BINARY=./plccli
SERVICE_PORT=8765
TEST_TIMEOUT=30
VERBOSE=false
